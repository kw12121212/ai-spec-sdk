{
  "name": "ai-spec-sdk",
  "version": "0.2.0",
  "description": "Polyglot JSON-RPC bridge for Claude Agent SDK and spec-driven workflows",
  "type": "module",
  "packageManager": "bun@latest",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "bin": {
    "ai-spec-bridge": "dist/src/cli.js"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "tsc --project tsconfig.json --noEmit",
    "test": "bun test",
    "start": "node dist/src/cli.js",
    "generate:types": "bun run scripts/generate-types.ts",
    "build:native": "bun build --compile src/cli.ts --outfile dist/ai-spec-bridge-native",
    "build:native:linux-x64": "bun build --compile --target=bun-linux-x64 src/cli.ts --outfile dist/ai-spec-bridge-linux-x64",
    "build:native:linux-arm64": "bun build --compile --target=bun-linux-arm64 src/cli.ts --outfile dist/ai-spec-bridge-linux-arm64",
    "build:native:macos-x64": "bun build --compile --target=bun-darwin-x64 src/cli.ts --outfile dist/ai-spec-bridge-macos-x64",
    "build:native:macos-arm64": "bun build --compile --target=bun-darwin-arm64 src/cli.ts --outfile dist/ai-spec-bridge-macos-arm64",
    "build:native:windows-x64": "bun build --compile --target=bun-windows-x64 src/cli.ts --outfile dist/ai-spec-bridge-windows-x64.exe",
    "build:native:all": "bash scripts/build-native-all.sh",
    "build:pack": "cd packages/client && npm pack && cd ../../clients/python && python -m build --wheel"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "Apache-2.0",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/js-yaml": "^4.0.9",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.84",
    "cron-parser": "^5.5.0",
    "js-yaml": "^4.1.1",
    "vscode-languageserver-protocol": "^3.17.5"
  }
}
